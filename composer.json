{
    "name": "caseproof/agents-assemble-exercise",
    "description": "Workshop exercise repo: a PHP utility library with intentional bugs for autonomous agent practice",
    "type": "library",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CaseproofUtils\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CaseproofUtils\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
